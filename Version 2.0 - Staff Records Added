import tkinter as tk
from tkinter import messagebox
from tkinter import *

window = tk.Tk()
window.geometry("230x100")
window.title("Login System")

def open_main_menu():
    new_window = Toplevel()
    new_window.title("Main Menu")
    new_window.geometry("230x100")

    def open_staff_member():
        new_window.destroy()

        staff_window = Toplevel()
        staff_window.title("Add Staff Record")
        staff_window.geometry("400x300")

        Label(staff_window, text="Add Staff Record").grid(row=1, column=5, padx=10, pady=5)

        Label(staff_window, text="Staff ID").grid(row=5, column=5, padx=10, pady=5)
        staff_id_entry = Entry(staff_window)
        staff_id_entry.grid(row=5, column=6, padx=10, pady=5)

        Label(staff_window, text="Firstname").grid(row=6, column=5, padx=10, pady=5)
        firstname_entry = Entry(staff_window)
        firstname_entry.grid(row=6, column=6, padx=10, pady=5)

        Label(staff_window, text="Surname").grid(row=7, column=5, padx=10, pady=5)
        surname_entry = Entry(staff_window)
        surname_entry.grid(row=7, column=6, padx=10, pady=5)

        Label(staff_window, text="Address 1").grid(row=8, column=5, padx=10, pady=5)
        address_1_entry = Entry(staff_window)
        address_1_entry.grid(row=8, column=6, padx=10, pady=5)

        Label(staff_window, text="Address 2").grid(row=9, column=5, padx=10, pady=5)
        address_2_entry = Entry(staff_window)
        address_2_entry.grid(row=9, column=6, padx=10, pady=5)

        Label(staff_window, text="Postcode").grid(row=10, column=5, padx=10, pady=5)
        postcode_entry = Entry(staff_window)
        postcode_entry.grid(row=10, column=6, padx=10, pady=5)

        def back_click():
            open_main_menu()
            staff_window.destroy()

        def save_click():
            staff_id = staff_id_entry.get()
            firstname = firstname_entry.get()
            surname = surname_entry.get()
            address_1 = address_1_entry.get()
            address_2 = address_2_entry.get()
            postcode = postcode_entry.get()

            file = open("newstaff.txt", "a")
            file.write(staff_id + "," + firstname + "," + surname + "," + address_1 + "," + address_2 + "," + postcode + "," + "\n")
            file.close()

            messagebox.showinfo("Success", "Staff Member Saved")

        Button(staff_window, text="Back", width=10, command=back_click).grid(row=11, column=5, padx=10, pady=5)
        Button(staff_window, text="Save", width=10, command=save_click).grid(row=11, column=7, padx=10, pady=5)

    Label(new_window, text="Main Menu").grid(row=0, column=5, padx=10, pady=5)
    Button(new_window, width=18, text="Add Staff Record", command=open_staff_member).grid(row=1, column=5, padx=10, pady=5)
    Button(new_window, width=15, text="Payroll").grid(row=2, column=5, padx=10, pady=5)

def button_click():
    username = key_entry.get()
    password = value_entry.get()

    if username in computing_words_dictionary:
        if computing_words_dictionary[username] == password:
            messagebox.showinfo("Login", "Login Successful!")
            window.withdraw()
            open_main_menu()
        else:
            messagebox.showerror("Error", "Incorrect Password")
    else:
        messagebox.showerror("Error", "Username Not Found")

computing_words_dictionary = {"123": "123"}

tk.Label(window, text="Username:").grid(row=0, column=0)
key_entry = tk.Entry(window)
key_entry.grid(row=0, column=1)

tk.Label(window, text="Password:").grid(row=1, column=0)
value_entry = tk.Entry(window)
value_entry.grid(row=1, column=1)

tk.Button(window, text="Login", width=10, command=button_click).grid(row=3, column=0, columnspan=2)

window.mainloop()
